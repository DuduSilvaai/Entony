# ============================
# ENTONY — Webhook Listener
# Evolution API → Meta CAPI
# ============================

# Meta Conversions API
META_PIXEL_ID=your_pixel_id
META_ACCESS_TOKEN=your_access_token
META_CAPI_VERSION=v18.0

# Evolution API (webhook security)
# This key must match what is configured in Evolution API webhook settings
EVOLUTION_API_KEY=your_evolution_api_key

# Mapeamento de etiquetas WhatsApp → Eventos Meta CAPI (JSON)
# Cada tag do WhatsApp dispara um evento diferente na Meta
CONVERSION_TAG_MAP_JSON={"vendido":"Purchase","nome sujo":"Lead_Disqualified_Credit","lead":"LeadSubmitted","carta de credito aprovada":"QualifiedLead"}
CONVERSION_DEFAULT_VALUE=0.0
CONVERSION_CURRENCY=BRL

# Server
HOST=0.0.0.0
PORT=9000
