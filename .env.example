# ============================
# ENTONY — Webhook Listener
# Evolution API → Meta CAPI
# ============================

# ── Meta Conversions API (OBRIGATÓRIO) ──────────────────────────────────────
META_PIXEL_ID=SEU_PIXEL_ID
META_ACCESS_TOKEN=SEU_ACCESS_TOKEN
META_CAPI_VERSION=v18.0

# ── Evolution API (segurança do webhook) ────────────────────────────────────
EVOLUTION_API_KEY=SUA_API_KEY_DA_EVOLUTION

# ── Mapeamento Etiqueta → Evento Meta (JSON) ────────────────────────────────
# Mapeia etiquetas do WhatsApp para nomes de eventos da Meta CAPI.
# As chaves são case-insensitive. Adicione quantas etiquetas precisar.
CONVERSION_TAG_MAP_JSON={"vendido":"Purchase","nome sujo":"Lead_Disqualified_Credit","lead":"LeadSubmitted","carta de credito aprovada":"QualifiedLead"}

# Mapeamento legado (usado apenas se CONVERSION_TAG_MAP_JSON estiver vazio)
CONVERSION_TAG_NAME=Pago
CONVERSION_EVENT_NAME=Purchase

# ── Configurações de conversão ───────────────────────────────────────────────
CONVERSION_DEFAULT_VALUE=0
CONVERSION_CURRENCY=BRL

# ── Supabase (auditoria e busca de fbclid) ──────────────────────────────────
SUPABASE_URL=https://seuproject.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key

# ── Servidor ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=9000
